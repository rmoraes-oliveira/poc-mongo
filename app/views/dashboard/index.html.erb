<div class="container-fluid py-4">
  <!-- Header com seleção de fornecedor -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h2 class="mb-0">
            <i class="fas fa-chart-line me-2"></i>
            Dashboard de Vendas
            <% if @manufacturer_name %>
              <small class="text-muted">- <%= @manufacturer_name %></small>
            <% end %>
          </h2>
        </div>
        <div>
          <!-- Dropdown de seleção de fornecedor -->
          <div class="dropdown">
            <button class="btn btn-primary dropdown-toggle" type="button" id="manufacturerDropdown" data-bs-toggle="dropdown">
              <i class="fas fa-filter me-2"></i>
              <%= @manufacturer_name || 'Selecionar Fornecedor' %>
            </button>
            <ul class="dropdown-menu" style="max-height: 300px; overflow-y: auto;">
              <li>
                <a class="dropdown-item" href="<%= dashboard_path %>">
                  <i class="fas fa-globe me-2"></i>Todos os Fornecedores
                </a>
              </li>
              <li><hr class="dropdown-divider"></li>
              <% @all_manufacturers.each do |manufacturer| %>
                <li>
                  <a class="dropdown-item <%= 'active' if @manufacturer_id == manufacturer.id.to_s %>" 
                     href="<%= dashboard_manufacturer_path(manufacturer.id) %>">
                    <i class="fas fa-building me-2"></i><%= manufacturer.name %>
                  </a>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Cards de estatísticas -->
  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card bg-primary text-white">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h4 class="card-title">Total de Items</h4>
              <h2 class="mb-0" id="total-items"><%= number_with_delimiter(@total_items) %></h2>
            </div>
            <div class="align-self-center">
              <i class="fas fa-shopping-cart fa-2x"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card bg-success text-white">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h4 class="card-title">Fornecedores</h4>
              <h2 class="mb-0"><%= @total_manufacturers %></h2>
            </div>
            <div class="align-self-center">
              <i class="fas fa-building fa-2x"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card bg-info text-white">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h4 class="card-title">Categorias</h4>
              <h2 class="mb-0"><%= @total_categories %></h2>
            </div>
            <div class="align-self-center">
              <i class="fas fa-tags fa-2x"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Conteúdo principal -->
  <div class="row">
    <!-- Regiões com mais vendas -->
    <div class="col-lg-6 mb-4">
      <div class="card h-100">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">
            <i class="fas fa-map-marked-alt me-2"></i>
            Vendas por Região
            <% if @manufacturer_name %>
              - <%= @manufacturer_name %>
            <% end %>
          </h5>
        </div>
        <div class="card-body">
          <div id="regional-sales-container">
            <div class="text-center py-4">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
              </div>
              <p class="mt-2">Carregando dados regionais...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Gráfico de comparação por categoria -->
    <div class="col-lg-6 mb-4">
      <div class="card h-100">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0">
            <i class="fas fa-chart-bar me-2"></i>
            Comparação por Categoria
          </h5>
        </div>
        <div class="card-body">
          <% if @manufacturer_id %>
            <div id="category-comparison-container">
              <div class="text-center py-4">
                <div class="spinner-border text-success" role="status">
                  <span class="visually-hidden">Carregando...</span>
                </div>
                <p class="mt-2">Carregando comparação...</p>
              </div>
            </div>
          <% else %>
            <div class="text-center py-5">
              <i class="fas fa-info-circle fa-3x text-muted mb-3"></i>
              <h5 class="text-muted">Selecione um fornecedor</h5>
              <p class="text-muted">Para ver a comparação por categoria, selecione um fornecedor específico.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <% if @manufacturer_id %>
    <!-- Gráficos detalhados de categoria (se fornecedor selecionado) -->
    <div class="row" id="category-charts-container">
      <!-- Os gráficos por categoria serão inseridos aqui via JavaScript -->
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Carregar dados regionais
  loadRegionalSales();
  
  // Carregar comparação por categoria se manufaturer selecionado
  <% if @manufacturer_id %>
    loadCategoryComparison('<%= @manufacturer_id %>');
  <% end %>
});

// Função para carregar dados de vendas regionais
function loadRegionalSales() {
  const manufacturerId = '<%= @manufacturer_id %>';
  const url = `/api/regional-sales${manufacturerId ? '?manufacturer_id=' + manufacturerId : ''}`;
  
  fetch(url)
    .then(response => response.json())
    .then(data => {
      createRegionalSalesChart(data.regional_sales);
    })
    .catch(error => {
      console.error('Erro ao carregar dados regionais:', error);
      document.getElementById('regional-sales-container').innerHTML = `
        <div class="text-center py-4 text-danger">
          <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
          <h5>Erro ao carregar dados</h5>
          <p>Não foi possível carregar os dados regionais.</p>
        </div>
      `;
    });
}

// Função para carregar comparação por categoria
function loadCategoryComparison(manufacturerId) {
  fetch(`/api/category-comparison/${manufacturerId}`)
    .then(response => response.json())
    .then(data => {
      createCategoryComparisonCharts(data.category_comparison);
    })
    .catch(error => {
      console.error('Erro ao carregar comparação por categoria:', error);
      document.getElementById('category-comparison-container').innerHTML = `
        <div class="text-center py-4 text-danger">
          <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
          <h5>Erro ao carregar dados</h5>
          <p>Não foi possível carregar a comparação por categoria.</p>
        </div>
      `;
    });
}

// Função para criar chart de vendas regionais
function createRegionalSalesChart(regionalData) {
  const container = document.getElementById('regional-sales-container');
  
  if (!regionalData || Object.keys(regionalData).length === 0) {
    container.innerHTML = `
      <div class="text-center py-4">
        <i class="fas fa-chart-pie fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">Nenhum dado encontrado</h5>
        <p class="text-muted">Não há dados de vendas para exibir.</p>
      </div>
    `;
    return;
  }

  // Ordenar regiões por total (decrescente)
  const sortedRegions = Object.entries(regionalData)
    .sort((a, b) => b[1].total - a[1].total);

  // Criar estrutura com gráfico de pizza e lista
  container.innerHTML = `
    <div class="row">
      <!-- Gráfico de Pizza -->
      <div class="col-md-6">
        <div class="text-center mb-2">
          <small class="text-muted">
            <i class="fas fa-mouse-pointer me-1"></i>
            Clique nas fatias para ver os estados
          </small>
        </div>
        <canvas id="regional-pie-chart" style="max-height: 300px; cursor: pointer;"></canvas>
      </div>
      
      <!-- Lista Ranking -->
      <div class="col-md-6">
        <h6 class="text-muted mb-3">
          Ranking de Vendas
          <small class="text-muted ms-2">
            <i class="fas fa-hand-pointer"></i> Clicável
          </small>
        </h6>
        <div id="regional-ranking-list">
          <!-- Lista será preenchida aqui -->
        </div>
      </div>
    </div>
  `;

  // Criar gráfico de pizza
  createRegionalPieChart(sortedRegions);
  
  // Criar lista de ranking
  createRegionalRankingList(sortedRegions);
}

// Função para criar gráfico de pizza/donut
function createRegionalPieChart(sortedRegions) {
  const ctx = document.getElementById('regional-pie-chart').getContext('2d');
  
  const labels = sortedRegions.map(([region]) => region);
  const data = sortedRegions.map(([, data]) => data.total);
  const percentages = sortedRegions.map(([, data]) => data.percentage);
  
  // Cores vibrantes para as regiões
  const colors = [
    '#FF6384', // Rosa/Vermelho
    '#36A2EB', // Azul
    '#FFCE56', // Amarelo
    '#4BC0C0', // Verde água
    '#9966FF'  // Roxo
  ];

  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: labels,
      datasets: [{
        data: data,
        backgroundColor: colors.slice(0, labels.length),
        borderColor: '#fff',
        borderWidth: 3,
        hoverOffset: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false // Vamos usar nossa própria lista
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const region = labels[context.dataIndex];
              const regionData = sortedRegions[context.dataIndex][1];
              return [
                `${region}: ${regionData.percentage}%`,
                `Items: ${regionData.total.toLocaleString()}`,
                `Valor: R$ ${regionData.total_value.toFixed(2)}`,
                `Preço médio: R$ ${regionData.avg_price.toFixed(2)}`
              ];
            }
          }
        }
      },
      cutout: '50%', // Fazer estilo donut
      animation: {
        animateRotate: true,
        duration: 1000
      },
      onClick: (event, elements) => {
        if (elements.length > 0) {
          const index = elements[0].index;
          const region = labels[index];
          console.log(`Clicou na região: ${region}`);
          showStateDetails(region);
        }
      }
    }
  });
}

// Função para criar lista de ranking
function createRegionalRankingList(sortedRegions) {
  const container = document.getElementById('regional-ranking-list');
  
  const colors = [
    '#FF6384', // Rosa/Vermelho
    '#36A2EB', // Azul
    '#FFCE56', // Amarelo
    '#4BC0C0', // Verde água
    '#9966FF'  // Roxo
  ];

  let html = '';
  
  sortedRegions.forEach(([region, data], index) => {
    const position = index + 1;
    const color = colors[index % colors.length];
    
    // Ícones de posição
    const positionIcon = position === 1 ? '🥇' : 
                        position === 2 ? '🥈' : 
                        position === 3 ? '🥉' : 
                        `${position}º`;

         html += `
       <div class="d-flex align-items-center mb-3 p-2 rounded clickable-region" 
            style="background-color: ${color}15; border-left: 4px solid ${color}; cursor: pointer; transition: all 0.3s ease;"
            onclick="showStateDetails('${region}')"
            onmouseover="this.style.backgroundColor='${color}25'; this.style.transform='translateX(5px)';"
            onmouseout="this.style.backgroundColor='${color}15'; this.style.transform='translateX(0px)';"
            title="Clique para ver os estados da região ${region}">
         <div class="me-3">
           <span style="font-size: 1.2em;">${positionIcon}</span>
         </div>
         <div class="flex-grow-1">
           <div class="d-flex justify-content-between align-items-center">
             <strong style="color: ${color};">${region}</strong>
             <div>
               <span class="badge" style="background-color: ${color}; color: white;">
                 ${data.percentage}%
               </span>
               <i class="fas fa-chevron-right ms-2" style="color: ${color}; font-size: 0.8em;"></i>
             </div>
           </div>
           <small class="text-muted">
             ${data.total.toLocaleString()} items • 
             R$ ${(data.total_value / 1000000).toFixed(1)}M • 
             <span style="color: ${color}; font-weight: bold;">Clique para detalhes</span>
           </small>
         </div>
       </div>
     `;
   });

   container.innerHTML = html;
}

// Função para criar gráficos de comparação por categoria
function createCategoryComparisonCharts(categories) {
  const container = document.getElementById('category-comparison-container');
  const chartsContainer = document.getElementById('category-charts-container');
  
  if (!categories || categories.length === 0) {
    container.innerHTML = `
      <div class="text-center py-4">
        <i class="fas fa-chart-bar fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">Nenhuma categoria encontrada</h5>
        <p class="text-muted">Este fornecedor não possui produtos em nenhuma categoria.</p>
      </div>
    `;
    return;
  }

  // Resumo na sidebar
  let summaryHtml = `
    <h6 class="text-muted mb-3">Categorias (${categories.length})</h6>
    <div class="list-group list-group-flush">
  `;

  categories.forEach((category, index) => {
    const myManufacturer = category.manufacturers.find(m => m.is_selected);
    const marketShare = myManufacturer ? myManufacturer.market_share : 0;

    summaryHtml += `
      <div class="list-group-item px-0">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="mb-1">${category.category_name}</h6>
            <small class="text-muted">${category.total_category_items.toLocaleString()} items no mercado</small>
          </div>
          <span class="badge ${marketShare > 20 ? 'bg-success' : marketShare > 10 ? 'bg-warning' : 'bg-secondary'}">
            ${marketShare}%
          </span>
        </div>
      </div>
    `;
  });

  summaryHtml += `</div>`;
  container.innerHTML = summaryHtml;

  // Gráficos detalhados
  if (chartsContainer) {
    let chartsHtml = '';

    categories.forEach((category, index) => {
      chartsHtml += `
        <div class="col-12 mb-4">
          <div class="card">
            <div class="card-header">
              <h5 class="mb-0">
                <i class="fas fa-chart-bar me-2"></i>
                ${category.category_name} - Comparação de Market Share
              </h5>
              <small class="text-muted">Total de ${category.total_category_items.toLocaleString()} items no mercado</small>
            </div>
            <div class="card-body">
              <canvas id="category-chart-${index}" style="max-height: 400px;"></canvas>
            </div>
          </div>
        </div>
      `;
    });

    chartsContainer.innerHTML = chartsHtml;

    // Criar gráficos Chart.js
    categories.forEach((category, index) => {
      createCategoryChart(category, index);
    });
  }
}

// Função para criar um gráfico individual por categoria
function createCategoryChart(category, index) {
  const ctx = document.getElementById(`category-chart-${index}`).getContext('2d');
  
  const manufacturers = category.manufacturers.slice(0, 10); // Top 10

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: manufacturers.map(m => m.name),
      datasets: [{
        label: 'Market Share (%)',
        data: manufacturers.map(m => m.market_share),
        backgroundColor: manufacturers.map(m => 
          m.is_selected ? '#198754' : '#6c757d'
        ),
        borderColor: manufacturers.map(m => 
          m.is_selected ? '#146c43' : '#5c636a'
        ),
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const manufacturer = manufacturers[context.dataIndex];
              return [
                `Market Share: ${manufacturer.market_share}%`,
                `Items: ${manufacturer.total_items.toLocaleString()}`,
                `Valor Total: R$ ${manufacturer.total_value.toFixed(2)}`,
                `Preço Médio: R$ ${manufacturer.avg_price.toFixed(2)}`
              ];
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          max: 100,
          ticks: {
            callback: function(value) {
              return value + '%';
            }
          }
        },
        x: {
          ticks: {
            maxRotation: 45
          }
        }
      }
    }
  });
}

// Função para abrir modal de estados quando clicar na região
function showStateDetails(region) {
  const manufacturerId = '<%= @manufacturer_id %>';
  const url = `/api/state-sales/${region}${manufacturerId ? '?manufacturer_id=' + manufacturerId : ''}`;
  
  // Criar modal
  const modalHtml = `
    <div class="modal fade" id="stateModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">
              <i class="fas fa-map-marker-alt me-2"></i>
              Estados da Região ${region}
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div id="state-modal-content">
              <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                  <span class="visually-hidden">Carregando...</span>
                </div>
                <p class="mt-2">Carregando dados dos estados...</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  `;
  
  // Remover modal anterior se existir
  const existingModal = document.getElementById('stateModal');
  if (existingModal) {
    existingModal.remove();
  }
  
  // Adicionar modal ao DOM
  document.body.insertAdjacentHTML('beforeend', modalHtml);
  
  // Mostrar modal
  const modal = new bootstrap.Modal(document.getElementById('stateModal'));
  modal.show();
  
  // Carregar dados dos estados
  fetch(url)
    .then(response => response.json())
    .then(data => {
      createStateChart(data.state_sales, region);
    })
    .catch(error => {
      console.error('Erro ao carregar dados dos estados:', error);
      document.getElementById('state-modal-content').innerHTML = `
        <div class="text-center py-4 text-danger">
          <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
          <h5>Erro ao carregar dados</h5>
          <p>Não foi possível carregar os dados dos estados.</p>
        </div>
      `;
    });
}

// Função para criar gráfico de estados
function createStateChart(stateData, region) {
  const container = document.getElementById('state-modal-content');
  
  if (!stateData || Object.keys(stateData).length === 0) {
    container.innerHTML = `
      <div class="text-center py-4">
        <i class="fas fa-map fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">Nenhum estado encontrado</h5>
        <p class="text-muted">Não há dados de vendas para esta região.</p>
      </div>
    `;
    return;
  }

  // Ordenar estados por total (decrescente)
  const sortedStates = Object.entries(stateData)
    .sort((a, b) => b[1].total - a[1].total);

  // Criar estrutura com abas: distribuição e sazonalidade
  container.innerHTML = `
    <!-- Abas de navegação -->
    <ul class="nav nav-tabs mb-3" id="stateTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="distribution-tab" data-bs-toggle="tab" data-bs-target="#distribution" type="button" role="tab">
          <i class="fas fa-chart-pie me-2"></i>Distribuição
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="seasonality-tab" data-bs-toggle="tab" data-bs-target="#seasonality" type="button" role="tab">
          <i class="fas fa-chart-line me-2"></i>Sazonalidade
        </button>
      </li>
    </ul>
    
    <!-- Conteúdo das abas -->
    <div class="tab-content" id="stateTabContent">
      <!-- Aba Distribuição -->
      <div class="tab-pane fade show active" id="distribution" role="tabpanel">
        <div class="row">
          <!-- Gráfico de Pizza dos Estados -->
          <div class="col-md-6">
            <h6 class="text-muted mb-3">Distribuição por Estado</h6>
            <canvas id="state-pie-chart" style="max-height: 300px;"></canvas>
          </div>
          
          <!-- Lista Ranking dos Estados -->
          <div class="col-md-6">
            <h6 class="text-muted mb-3">Ranking de Estados</h6>
            <div id="state-ranking-list">
              <!-- Lista será preenchida aqui -->
            </div>
          </div>
        </div>
      </div>
      
      <!-- Aba Sazonalidade -->
      <div class="tab-pane fade" id="seasonality" role="tabpanel">
        <div class="row">
          <div class="col-12">
            <h6 class="text-muted mb-3">
              <i class="fas fa-chart-bar me-2"></i>
              Sazonalidade Regional - Todos os Estados por Mês
            </h6>
            <div id="seasonality-chart-container">
              <div class="text-center py-4 text-muted">
                <div class="spinner-border text-primary" role="status">
                  <span class="visually-hidden">Carregando...</span>
                </div>
                <p class="mt-2">Carregando dados de sazonalidade...</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  `;

  // Criar gráfico de pizza dos estados
  createStatePieChart(sortedStates, region);
  
  // Criar lista de ranking dos estados
  createStateRankingList(sortedStates);
  
  // Configurar listener para aba de sazonalidade
  setupSeasonalityTab(region);
}

// Função para criar gráfico de pizza dos estados
function createStatePieChart(sortedStates, region) {
  const ctx = document.getElementById('state-pie-chart').getContext('2d');
  
  const labels = sortedStates.map(([state]) => state);
  const data = sortedStates.map(([, data]) => data.total);
  
  // Cores mais variadas para os estados
  const colors = [
    '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF',
    '#FF9F40', '#FF6384', '#C9CBCF', '#4BC0C0', '#FF6384'
  ];

  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: labels,
      datasets: [{
        data: data,
        backgroundColor: colors.slice(0, labels.length),
        borderColor: '#fff',
        borderWidth: 2,
        hoverOffset: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const state = labels[context.dataIndex];
              const stateData = sortedStates[context.dataIndex][1];
              return [
                `${state}: ${stateData.percentage}%`,
                `Items: ${stateData.total.toLocaleString()}`,
                `Valor: R$ ${stateData.total_value.toFixed(2)}`,
                `Preço médio: R$ ${stateData.avg_price.toFixed(2)}`
              ];
            }
          }
        }
      },
      cutout: '50%',
      animation: {
        animateRotate: true,
        duration: 800
      }
    }
  });
}

// Função para criar lista de ranking dos estados
function createStateRankingList(sortedStates) {
  const container = document.getElementById('state-ranking-list');
  
  const colors = [
    '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF',
    '#FF9F40', '#FF6384', '#C9CBCF', '#4BC0C0', '#FF6384'
  ];

  let html = '';
  
  sortedStates.forEach(([state, data], index) => {
    const position = index + 1;
    const color = colors[index % colors.length];
    
    const positionIcon = position === 1 ? '🥇' : 
                        position === 2 ? '🥈' : 
                        position === 3 ? '🥉' : 
                        `${position}º`;

    html += `
      <div class="d-flex align-items-center mb-2 p-2 rounded" style="background-color: ${color}15; border-left: 3px solid ${color};">
        <div class="me-2">
          <span style="font-size: 1em;">${positionIcon}</span>
        </div>
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between align-items-center">
            <strong style="color: ${color}; font-size: 0.9em;">${state}</strong>
            <span class="badge" style="background-color: ${color}; color: white; font-size: 0.8em;">
              ${data.percentage}%
            </span>
          </div>
          <small class="text-muted" style="font-size: 0.75em;">
            ${data.total.toLocaleString()} items • 
            R$ ${(data.total_value / 1000000).toFixed(1)}M
          </small>
        </div>
      </div>
    `;
  });

     container.innerHTML = html;
}

// Função para configurar a aba de sazonalidade
function setupSeasonalityTab(region) {
  // Adicionar listener para quando a aba de sazonalidade for ativada
  const seasonalityTab = document.getElementById('seasonality-tab');
  
  seasonalityTab.addEventListener('shown.bs.tab', function() {
    // Carregar dados de sazonalidade regional apenas quando a aba for ativada
    loadRegionalSeasonality(region);
  });
}

// Função para carregar dados de sazonalidade de uma região
function loadRegionalSeasonality(region) {
  const manufacturerId = '<%= @manufacturer_id %>';
  const url = `/api/regional-seasonality/${region}${manufacturerId ? '?manufacturer_id=' + manufacturerId : ''}`;
  
  // Mostrar loading se ainda não carregou
  const container = document.getElementById('seasonality-chart-container');
  if (!container.dataset.loaded) {
    container.innerHTML = `
      <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Carregando...</span>
        </div>
        <p class="mt-2">Carregando sazonalidade da região ${region}...</p>
      </div>
    `;
  
    // Carregar dados
    fetch(url)
      .then(response => response.json())
      .then(data => {
        createRegionalSeasonalityChart(data.seasonality, region);
        container.dataset.loaded = 'true'; // Marcar como carregado
      })
      .catch(error => {
        console.error('Erro ao carregar sazonalidade regional:', error);
        container.innerHTML = `
          <div class="text-center py-4 text-danger">
            <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
            <h5>Erro ao carregar dados</h5>
            <p>Não foi possível carregar os dados de sazonalidade da região.</p>
          </div>
        `;
      });
  }
}

// Função para criar gráfico de sazonalidade regional (todos os estados por mês)
function createRegionalSeasonalityChart(seasonalityData, region) {
  const container = document.getElementById('seasonality-chart-container');
  
  if (!seasonalityData || Object.keys(seasonalityData).length === 0) {
    container.innerHTML = `
      <div class="text-center py-4">
        <i class="fas fa-calendar fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">Sem dados de sazonalidade</h5>
        <p class="text-muted">Não há dados suficientes para a região ${region}.</p>
      </div>
    `;
    return;
  }

  // Preparar estrutura do gráfico
  container.innerHTML = `
    <div class="card">
      <div class="card-header">
        <h6 class="mb-0">
          <i class="fas fa-chart-bar me-2"></i>
          Sazonalidade por Estado - Região ${region}
        </h6>
        <small class="text-muted">Vendas mensais agrupadas por estado</small>
      </div>
      <div class="card-body">
        <div style="position: relative; height: 450px; max-width: 100%;">
          <canvas id="seasonality-chart"></canvas>
        </div>
        <div class="mt-3">
          <div class="row">
            <div class="col-md-8">
              <h6 class="text-muted">Celebrações e Eventos:</h6>
              <div id="celebrations-info" class="small">
                <!-- Informações das celebrações serão inseridas aqui -->
              </div>
            </div>
            <div class="col-md-4">
              <h6 class="text-muted">Linha de Tendência:</h6>
              <div id="trend-info" class="small">
                <!-- Informações da tendência serão inseridas aqui -->
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  `;

  // Preparar dados para gráfico agrupado
  const monthNames = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
  const months = [];
  const celebrations = [];
  
  // Coletar todos os estados únicos
  const allStates = new Set();
  Object.values(seasonalityData).forEach(monthData => {
    Object.keys(monthData.states || {}).forEach(state => allStates.add(state));
  });
  
  const statesList = Array.from(allStates).sort();
  
  // Cores diferenciadas para cada estado
  const stateColors = [
    '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF',
    '#FF9F40', '#C9CBCF', '#FF6384', '#36A2EB', '#FFCE56'
  ];
  
  // Preparar datasets (um para cada estado)
  const datasets = statesList.map((state, index) => {
    const color = stateColors[index % stateColors.length];
    const data = [];
    
    for (let monthNum = 1; monthNum <= 12; monthNum++) {
      const monthData = seasonalityData[monthNum];
      const stateData = monthData?.states?.[state];
      data.push(stateData?.total || 0);
    }
    
    return {
      label: state,
      data: data,
      backgroundColor: color.replace(')', ', 0.7)').replace('rgb', 'rgba'),
      borderColor: color,
      borderWidth: 1,
      maxBarThickness: 30
    };
  });
  
  // Calcular linha de média de tendência
  const trendData = [];
  let totalSales = 0;
  let totalMonths = 0;
  
  for (let monthNum = 1; monthNum <= 12; monthNum++) {
    const monthData = seasonalityData[monthNum];
    const monthTotal = monthData?.total || 0;
    trendData.push(monthTotal);
    totalSales += monthTotal;
    if (monthTotal > 0) totalMonths++;
  }
  
  const overallAverage = totalMonths > 0 ? totalSales / 12 : 0;
  const averageLineData = new Array(12).fill(overallAverage);
  
  // Adicionar dataset da linha de média
  datasets.push({
    type: 'line',
    label: 'Média Regional',
    data: averageLineData,
    borderColor: '#ff6b35',
    backgroundColor: 'rgba(255, 107, 53, 0.1)',
    borderWidth: 3,
    pointRadius: 5,
    pointHoverRadius: 7,
    pointBackgroundColor: '#ff6b35',
    pointBorderColor: '#ffffff',
    pointBorderWidth: 2,
    tension: 0,
    fill: false,
    order: 0, // Aparecer por cima das barras
    borderDash: [5, 5] // Linha tracejada para destacar
  });
  
  // Preparar labels dos meses e celebrações
  for (let monthNum = 1; monthNum <= 12; monthNum++) {
    const monthData = seasonalityData[monthNum];
    months.push(monthNames[monthNum - 1]);
    celebrations.push(monthData?.celebration || 'Sem dados');
  }

  // Criar gráfico agrupado
  const ctx = document.getElementById('seasonality-chart').getContext('2d');
  
  // Destruir gráfico anterior se existir
  if (window.seasonalityChart && typeof window.seasonalityChart.destroy === 'function') {
    window.seasonalityChart.destroy();
  }
  
  window.seasonalityChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: months,
      datasets: datasets
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: {
        mode: 'index',
        intersect: false
      },
      plugins: {
        legend: {
          position: 'top',
          labels: {
            usePointStyle: true,
            padding: 10,
            font: {
              size: 11
            },
            generateLabels: function(chart) {
              const original = Chart.defaults.plugins.legend.labels.generateLabels;
              const labels = original.call(this, chart);
              
              // Personalizar a label da linha de média
              labels.forEach(label => {
                if (label.text === 'Média Regional') {
                  label.text = 'Média Regional (referência)';
                  label.lineDash = [5, 5];
                }
              });
              
              return labels;
            }
          }
        },
        tooltip: {
          callbacks: {
            title: function(context) {
              const index = context[0].dataIndex;
              return `${months[index]} - ${celebrations[index]}`;
            },
            label: function(context) {
              const datasetLabel = context.dataset.label;
              const value = context.parsed.y;
              
              if (datasetLabel === 'Média Regional') {
                return `${datasetLabel}: ${value.toLocaleString()} vendas (linha de referência)`;
              } else {
                return `${datasetLabel}: ${value.toLocaleString()} vendas`;
              }
            },
            afterBody: function(context) {
              // Adicionar informação extra para a linha de média
              const hasAverage = context.some(item => item.dataset.label === 'Média Regional');
              if (hasAverage) {
                return ['', 'A linha tracejada representa a média mensal da região'];
              }
              return [];
            }
          }
        }
      },
      scales: {
        x: {
          title: {
            display: true,
            text: 'Meses do Ano',
            font: {
              size: 12
            }
          },
          grid: {
            display: false
          }
        },
        y: {
          type: 'linear',
          display: true,
          title: {
            display: true,
            text: 'Número de Vendas',
            font: {
              size: 12
            }
          },
          beginAtZero: true,
          ticks: {
            callback: function(value) {
              return value.toLocaleString();
            }
          },
          grid: {
            color: 'rgba(0, 0, 0, 0.1)',
            drawBorder: false
          }
        }
      },
      // Otimizações de performance
      animation: {
        duration: 750
      },
      elements: {
        bar: {
          borderRadius: 2
        }
      }
    }
  });

  // Mostrar informações das celebrações e tendência
  createRegionalCelebrationsInfo(seasonalityData);
  createTrendInfo(seasonalityData, overallAverage);
}

// Função para criar informações das celebrações regionais
function createRegionalCelebrationsInfo(seasonalityData) {
  const container = document.getElementById('celebrations-info');
  
  // Usar fragmento de documento para melhor performance
  const fragment = document.createDocumentFragment();
  const rowDiv = document.createElement('div');
  rowDiv.className = 'row';
  
  // Processar apenas os 12 meses em ordem
  const monthNames = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
  
  for (let monthNum = 1; monthNum <= 12; monthNum++) {
    const data = seasonalityData[monthNum];
    
    if (data) {
      // Calcular intensidade baseada no total de vendas
      let intensityClass = 'text-muted';
      let intensityIcon = 'fas fa-minus';
      
      const totalSales = data.total || 0;
      const avgSales = Object.values(seasonalityData).reduce((sum, m) => sum + (m.total || 0), 0) / 12;
      
      if (totalSales > avgSales * 1.2) {
        intensityClass = 'text-success';
        intensityIcon = 'fas fa-arrow-up';
      } else if (totalSales < avgSales * 0.8) {
        intensityClass = 'text-danger';
        intensityIcon = 'fas fa-arrow-down';
      }
      
      const colDiv = document.createElement('div');
      colDiv.className = 'col-md-6 col-lg-4 mb-2';
      
      colDiv.innerHTML = `
        <div class="d-flex align-items-center">
          <strong class="me-2">${monthNames[monthNum - 1]}:</strong>
          <span class="me-2 text-truncate" style="max-width: 140px;" title="${data.celebration || 'Sem dados'}">${data.celebration || 'Sem dados'}</span>
          <span class="${intensityClass}" title="Total: ${totalSales.toLocaleString()} vendas">
            <i class="${intensityIcon}"></i>
            ${totalSales.toLocaleString()}
          </span>
        </div>
      `;
      
      rowDiv.appendChild(colDiv);
    }
  }
  
  fragment.appendChild(rowDiv);
  
  // Limpar container e adicionar novo conteúdo de uma vez
  container.innerHTML = '';
  container.appendChild(fragment);
}

// Função para criar informações da linha de tendência
function createTrendInfo(seasonalityData, overallAverage) {
  const container = document.getElementById('trend-info');
  
  // Calcular estatísticas da tendência
  const monthlyTotals = [];
  for (let monthNum = 1; monthNum <= 12; monthNum++) {
    const monthData = seasonalityData[monthNum];
    monthlyTotals.push(monthData?.total || 0);
  }
  
  const maxMonth = Math.max(...monthlyTotals);
  const minMonth = Math.min(...monthlyTotals.filter(v => v > 0));
  const maxMonthIndex = monthlyTotals.indexOf(maxMonth) + 1;
  const minMonthIndex = monthlyTotals.indexOf(minMonth) + 1;
  
  const monthNames = ['', 'Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
  
  container.innerHTML = `
    <div class="d-flex align-items-center mb-2">
      <div style="width: 20px; height: 3px; background: #ff6b35; border: 1px dashed #fff; margin-right: 8px;"></div>
      <span class="text-muted small">Linha de Referência</span>
    </div>
    <div class="mb-2">
      <strong>Média Regional:</strong><br>
      <span class="text-primary">${Math.round(overallAverage).toLocaleString()} vendas/mês</span>
    </div>
    <div class="mb-2">
      <strong>Pico:</strong><br>
      <span class="text-success">${monthNames[maxMonthIndex]} (${maxMonth.toLocaleString()})</span>
    </div>
    <div class="mb-2">
      <strong>Vale:</strong><br>
      <span class="text-danger">${monthNames[minMonthIndex]} (${minMonth.toLocaleString()})</span>
    </div>
    <div class="small text-muted">
      <i class="fas fa-info-circle me-1"></i>
      A linha tracejada facilita a comparação entre meses e estados
    </div>
  `;
}
</script> 